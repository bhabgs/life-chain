#!/bin/bash
#
# Git Pre-commit Hook - 保护关键文件
#
# 这个脚本会在提交前检查是否修改了受保护的文件
# 如果修改了，会给出警告并要求确认

set -e

# 颜色定义
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# 受保护的文件列表
PROTECTED_FILES=(
  "CLAUDE.md"
  ".claude/skills/*.md"
  "docs/技术架构设计.md"
  "docs/页面功能目录.md"
  "docs/多端策略分析.md"
  "package.json"
  "pnpm-workspace.yaml"
  "tsconfig.base.json"
  ".github/CODEOWNERS"
  ".github/workflows/*.yml"
  "**/prisma/schema.prisma"
)

# 获取当前提交的文件列表
STAGED_FILES=$(git diff --cached --name-only)

# 检查是否修改了受保护的文件
PROTECTED_MODIFIED=()

for file in $STAGED_FILES; do
  for pattern in "${PROTECTED_FILES[@]}"; do
    # 使用通配符匹配
    if [[ $file == $pattern ]] || [[ $file =~ $pattern ]]; then
      PROTECTED_MODIFIED+=("$file")
      break
    fi
  done
done

# 如果没有修改受保护的文件，直接通过
if [ ${#PROTECTED_MODIFIED[@]} -eq 0 ]; then
  echo -e "${GREEN}✓ 没有修改受保护的文件${NC}"
  exit 0
fi

# 显示警告
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}⚠️  警告：你正在修改受保护的文件！${NC}"
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${RED}以下文件受到保护，需要特定权限人员审批：${NC}"
echo ""

for file in "${PROTECTED_MODIFIED[@]}"; do
  echo -e "  ${RED}✗${NC} $file"
done

echo ""
echo -e "${YELLOW}这些文件的修改需要：${NC}"
echo -e "  1. 项目负责人或技术负责人审批（CODEOWNERS）"
echo -e "  2. 详细的修改说明（在 PR 中）"
echo -e "  3. 团队成员知晓"
echo ""

# 询问是否继续
read -p "$(echo -e ${YELLOW}是否确认提交这些修改？[y/N]:${NC} )" -n 1 -r
echo ""

if [[ $REPLY =~ ^[Yy]$ ]]; then
  echo -e "${GREEN}✓ 继续提交，请确保在 PR 中说明修改原因${NC}"
  echo ""
  echo -e "${YELLOW}提示：${NC}"
  echo -e "  - 在 commit message 中添加 [PROTECTED] 标签"
  echo -e "  - 在 PR 描述中详细说明修改原因"
  echo -e "  - @ 相关负责人进行审查"
  exit 0
else
  echo -e "${RED}✗ 提交已取消${NC}"
  echo ""
  echo -e "${YELLOW}如果你确实需要修改这些文件：${NC}"
  echo -e "  1. 与相关负责人沟通"
  echo -e "  2. 在团队会议中讨论"
  echo -e "  3. 记录修改原因"
  exit 1
fi
